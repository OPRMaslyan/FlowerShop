<Page x:Class="FlowerShop.Pages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Корзина" Height="800" Width="1000">
    <Grid Background="{StaticResource MainBackground}">

        <!--Верхняя панель -->
        <Border Height="80" Background="White" VerticalAlignment="Top">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,0">
                    <Image Source="/Images/logo.png" Height="40" Margin="0,0,10,0"/>
                    <TextBlock Text="Flower Shop" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Каталог" Style="{StaticResource MenuButton}" Click="BtnCatalog_Click" Margin="0,0,20,0"/>
                    <Button Content="О нас" Style="{StaticResource MenuButton}" Click="BtnAbout_Click" Margin="0,0,20,0"/>
                    <Button Content="Меню" Style="{StaticResource MenuButton}" Click="BtnMenu_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <Button Content="🛒" Style="{StaticResource IconButton}" Click="BtnCart_Click" Margin="0,0,10,0"/>
                    <Button Content="👤" Style="{StaticResource IconButton}" Click="BtnProfile_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!--Контент -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,80,0,0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">

                <!--Заголовок -->
                <TextBlock Text="🛒 Корзина" 
                           FontSize="36" 
                           FontWeight="Bold" 
                           Foreground="Black" 
                           Margin="0,30,0,30" 
                           TextAlignment="Center"/>

                <!--Список товаров -->
                <ItemsControl x:Name="ItemsControlCart">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" 
                                    CornerRadius="15" 
                                    Padding="20" 
                                    Margin="0,0,0,15" 
                                    Width="800">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>

                                    <!--Товар -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FlowerName}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Price, StringFormat={}{0:F2} ₽}" 
                                                   Foreground="Gray"
                                                   FontSize="14"/>
                                    </StackPanel>

                                    <!--Количество -->
                                    <StackPanel Grid.Column="1" 
                                                Orientation="Horizontal" 
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Button Content="➖" 
                                                Width="35" Height="35"
                                                Style="{StaticResource IconButton}"
                                                FontSize="14"
                                                Tag="{Binding Id}"
                                                Click="BtnDecrease_Click"/>
                                        <TextBlock Text="{Binding Quantity}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold"
                                                   Margin="10,0"
                                                   VerticalAlignment="Center"
                                                   MinWidth="30"
                                                   TextAlignment="Center"/>
                                        <Button Content="➕" 
                                                Width="35" Height="35"
                                                Style="{StaticResource IconButton}"
                                                FontSize="14"
                                                Tag="{Binding Id}"
                                                Click="BtnIncrease_Click"/>
                                    </StackPanel>

                                    <!--Сумма и удалить -->
                                    <StackPanel Grid.Column="2" 
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Total, StringFormat={}{0:F2} ₽}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold"
                                                   Foreground="DarkGreen"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,0,0,5"/>
                                        <Button Content="🗑️ Удалить" 
                                                Style="{StaticResource GrayButton}"
                                                FontSize="12"
                                                Height="35"
                                                Width="120"
                                                Tag="{Binding Id}"
                                                Click="BtnRemove_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--Пустая корзина -->
                <TextBlock x:Name="TxtEmptyCart" 
                           Text="Корзина пуста" 
                           FontSize="24" 
                           Foreground="Gray" 
                           TextAlignment="Center" 
                           Margin="0,50,0,0"
                           Visibility="Collapsed"/>

                <!--Итого -->
                <Border Background="White" 
                        CornerRadius="20" 
                        Padding="30" 
                        Width="800" 
                        Margin="0,30,0,30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Итого:" FontSize="20" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtTotal" 
                                       Text="0.00 ₽" 
                                       FontSize="32" 
                                       FontWeight="Bold" 
                                       Foreground="DarkGreen"/>
                        </StackPanel>
                        <Button Grid.Column="1" 
                                Content="📦 Оформить заказ" 
                                Style="{StaticResource GreenButton}"
                                Width="250"
                                VerticalAlignment="Center"
                                Click="BtnCheckout_Click"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>