<Page x:Class="FlowerShop.Pages.PaymentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Оплата заказа" Height="800" Width="1000">
    <Grid Background="{StaticResource MainBackground}">

        <!-- Верхняя панель -->
        <Border Height="80" Background="White" VerticalAlignment="Top">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,0">
                    <Image Source="/Images/logo.png" Height="40" Margin="0,0,10,0"/>
                    <TextBlock Text="Flower Shop" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Каталог" Style="{StaticResource MenuButton}" Click="BtnCatalog_Click" Margin="0,0,20,0"/>
                    <Button Content="О нас" Style="{StaticResource MenuButton}" Click="BtnAbout_Click" Margin="0,0,20,0"/>
                    <Button Content="Меню" Style="{StaticResource MenuButton}" Click="BtnMenu_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <Button Content="🛒" Style="{StaticResource IconButton}" Click="BtnCart_Click" Margin="0,0,10,0"/>
                    <Button Content="👤" Style="{StaticResource IconButton}" Click="BtnProfile_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Контент -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,80,0,0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">

                <!-- Заголовок -->
                <TextBlock Text="Оплата заказа" 
                           FontSize="36" 
                           FontWeight="Bold" 
                           Foreground="Black" 
                           Margin="0,30,0,30" 
                           TextAlignment="Center"/>

                <!-- Информация о заказе -->
                <Border Background="White" CornerRadius="20" Padding="30" Width="700" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock x:Name="TxtOrderInfo" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Сумма к оплате:" FontSize="16" Foreground="#555"/>
                        <TextBlock x:Name="TxtAmount" 
                                   Text="0.00 ₽" 
                                   FontSize="32" 
                                   FontWeight="Bold" 
                                   Foreground="DarkGreen"/>
                    </StackPanel>
                </Border>

                <!-- Выбор способа оплаты -->
                <Border Background="White" CornerRadius="20" Padding="30" Width="700" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Выберите способ оплаты" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                        <!-- QR-код (СБП) -->
                        <RadioButton x:Name="RadioQR" 
                                     GroupName="PaymentMethod" 
                                     FontSize="16" 
                                     Margin="0,0,0,15"
                                     Checked="PaymentMethod_Checked">
                            <RadioButton.Content>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Оплата по QR-коду (СБП)" FontSize="16" FontWeight="Medium"/>
                                </StackPanel>
                            </RadioButton.Content>
                        </RadioButton>

                        <!-- QR-код и реквизиты -->
                        <Border x:Name="QRSection" 
                                Background="#F8F9FA" 
                                CornerRadius="15" 
                                Padding="30" 
                                Margin="0,0,0,20"
                                Visibility="Visible">
                            <StackPanel>
                                <!-- QR-код -->
                                <Border Background="White" 
                                        CornerRadius="15" 
                                        Padding="20" 
                                        Margin="0,0,0,20"
                                        HorizontalAlignment="Center"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1">
                                    <Image x:Name="ImgQRCode" 
                                           Source="/Images/qr_payment.png" 
                                           Width="280" 
                                           Height="280"
                                           Stretch="Uniform"/>
                                </Border>

                                <!-- Реквизиты -->
                                <Border Background="White" 
                                        CornerRadius="12" 
                                        Padding="20"
                                        Margin="0,0,0,15"
                                        BorderBrush="#FFD700"
                                        BorderThickness="2">
                                    <StackPanel>
                                        <TextBlock Text="Реквизиты для оплаты" 
                                                   FontSize="16" 
                                                   FontWeight="Bold" 
                                                   Foreground="#212121"
                                                   Margin="0,0,0,15"/>
                                        
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="Получатель:" FontSize="12" Foreground="#757575"/>
                                            <TextBlock Text="Заполотский Илья Алексеевич" 
                                                       FontSize="16" 
                                                       FontWeight="Bold"
                                                       Foreground="#212121"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="Телефон:" FontSize="12" Foreground="#757575"/>
                                            <TextBlock Text="+7 (980) 318-79-00" 
                                                       FontSize="16" 
                                                       FontWeight="Medium"
                                                       Foreground="#212121"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="Банк:" FontSize="12" Foreground="#757575"/>
                                            <TextBlock Text="Т-Банк (Тинькофф)" 
                                                       FontSize="16" 
                                                       FontWeight="Medium"
                                                       Foreground="#FFDD2D"/>
                                        </StackPanel>

                                        <Border Background="#FFF8E1" 
                                                CornerRadius="8" 
                                                Padding="10"
                                                Margin="0,10,0,0">
                                            <TextBlock Text="Отсканируйте QR-код в приложении вашего банка" 
                                                       FontSize="12" 
                                                       Foreground="#FF8F00"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Инструкция -->
                                <Border Background="#E3F2FD" 
                                        CornerRadius="10" 
                                        Padding="15"
                                        Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="Как оплатить:" 
                                                   FontSize="14" 
                                                   FontWeight="Bold" 
                                                   Foreground="#1976D2"
                                                   Margin="0,0,0,10"/>
                                        <TextBlock Text="1. Откройте приложение банка" FontSize="13" Margin="0,0,0,5"/>
                                        <TextBlock Text="2. Выберите Оплата по QR-коду" FontSize="13" Margin="0,0,0,5"/>
                                        <TextBlock Text="3. Отсканируйте QR-код выше" FontSize="13" Margin="0,0,0,5"/>
                                        <TextBlock Text="4. Подтвердите перевод на сумму заказа" FontSize="13"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Оплата при получении -->
                        <RadioButton x:Name="RadioCash" 
                                     GroupName="PaymentMethod" 
                                     FontSize="16" 
                                     Margin="0,0,0,15"
                                     Checked="PaymentMethod_Checked">
                            <RadioButton.Content>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Оплата при получении" FontSize="16" FontWeight="Medium"/>
                                </StackPanel>
                            </RadioButton.Content>
                        </RadioButton>

                        <Border x:Name="CashSection" 
                                Background="#E8F5E9" 
                                CornerRadius="10" 
                                Padding="20"
                                Margin="0,0,0,15"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Оплата при получении" 
                                           FontSize="16" 
                                           FontWeight="Bold" 
                                           Foreground="#2E7D32"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="Вы сможете оплатить заказ наличными или банковской картой при получении." 
                                           FontSize="14" 
                                           Foreground="#1B5E20"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="Пожалуйста, имейте точную сумму или будьте готовы оплатить картой." 
                                           FontSize="12" 
                                           Foreground="#FF6F00"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- Кнопки действий -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <Button Content="Я оплатил" 
                            x:Name="BtnConfirmPayment"
                            Style="{StaticResource GreenButton}"
                            Width="220"
                            Margin="0,0,15,0"
                            Click="BtnConfirmPayment_Click"/>
                    <Button Content="Отмена" 
                            Style="{StaticResource GrayButton}"
                            Width="150"
                            Click="BtnCancel_Click"/>
                </StackPanel>

                <!-- Подсказка -->
                <TextBlock x:Name="TxtHint" 
                           Text="Выберите способ оплаты выше" 
                           Foreground="Gray" 
                           TextAlignment="Center" 
                           FontSize="14" 
                           Margin="0,15,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>