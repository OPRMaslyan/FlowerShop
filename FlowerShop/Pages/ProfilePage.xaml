<Page x:Class="FlowerShop.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Профиль" Height="800" Width="1000">
    <Grid Background="{StaticResource MainBackground}">

        <!--Верхняя панель -->
        <Border Height="80" Background="White" VerticalAlignment="Top">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,0">
                    <Image Source="/Images/logo.png" Height="40" Margin="0,0,10,0"/>
                    <TextBlock Text="Flower Shop" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Каталог" Style="{StaticResource MenuButton}" Click="BtnCatalog_Click" Margin="0,0,20,0"/>
                    <Button Content="О нас" Style="{StaticResource MenuButton}" Click="BtnAbout_Click" Margin="0,0,20,0"/>
                    <Button Content="Меню" Style="{StaticResource MenuButton}" Click="BtnMenu_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <Button Content="🛒" Style="{StaticResource IconButton}" Click="BtnCart_Click" Margin="0,0,10,0"/>
                    <Button Content="👤" Style="{StaticResource IconButton}" Click="BtnProfile_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!--Контент -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,80,0,0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">

                <!--Заголовок -->
                <TextBlock Text="👤 Профиль пользователя" 
                           FontSize="36" 
                           FontWeight="Bold" 
                           Foreground="Black" 
                           Margin="0,30,0,30" 
                           TextAlignment="Center"/>

                <!--Информация о пользователе -->
                <Border Background="White" CornerRadius="20" Padding="40" Width="600" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="Личные данные" FontSize="24" FontWeight="Medium" Foreground="Black" TextAlignment="Center" Margin="0,0,0,20"/>

                        <!--Логин -->
                        <TextBlock Text="Логин" FontSize="16" FontWeight="Medium" Margin="0,0,0,5"/>
                        <TextBox x:Name="TBoxUsername" 
                                 Style="{StaticResource FilterTextBox}"
                                 Margin="0,0,0,15"
                                 IsEnabled="False"/>

                        <!--Email -->
                        <TextBlock Text="Email" FontSize="16" FontWeight="Medium" Margin="0,0,0,5"/>
                        <TextBox x:Name="TBoxEmail" 
                                 Style="{StaticResource FilterTextBox}"
                                 Margin="0,0,0,15"
                                 IsEnabled="False"/>

                        <!--Роль -->
                        <TextBlock Text="Роль" FontSize="16" FontWeight="Medium" Margin="0,0,0,5"/>
                        <TextBox x:Name="TBoxRole" 
                                 Style="{StaticResource FilterTextBox}"
                                 Margin="0,0,0,20"
                                 IsEnabled="False"/>

                        <!--Дата регистрации -->
                        <TextBlock Text="Дата регистрации" FontSize="16" FontWeight="Medium" Margin="0,0,0,5"/>
                        <TextBox x:Name="TBoxCreatedAt" 
                                 Style="{StaticResource FilterTextBox}"
                                 Margin="0,0,0,20"
                                 IsEnabled="False"/>

                        <!--Кнопки управления -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Button x:Name="BtnEdit" 
                                    Content="✏️ Редактировать" 
                                    Style="{StaticResource GreenButton}"
                                    Width="180"
                                    Margin="0,0,10,0"
                                    Click="BtnEdit_Click"/>
                            <Button x:Name="BtnSave" 
                                    Content="💾 Сохранить" 
                                    Style="{StaticResource GreenButton}"
                                    Width="180"
                                    Margin="0,0,10,0"
                                    Visibility="Collapsed"
                                    Click="BtnSave_Click"/>
                            <Button x:Name="BtnCancel" 
                                    Content="❌ Отмена" 
                                    Style="{StaticResource GrayButton}"
                                    Width="130"
                                    Visibility="Collapsed"
                                    Click="BtnCancel_Click"/>
                        </StackPanel>

                        <!--Кнопка удаления профиля -->
                        <Button x:Name="BtnDeleteProfile" 
                                Content="🗑️ Удалить профиль" 
                                Style="{StaticResource GrayButton}"
                                Width="250"
                                Margin="0,20,0,0"
                                Background="#DC3545"
                                Click="BtnDeleteProfile_Click"/>

                        <!--Сообщение -->
                        <TextBlock x:Name="TxtMessage" 
                                   TextAlignment="Center" 
                                   FontSize="14" 
                                   Margin="0,15,0,0"
                                   Visibility="Collapsed"/>

                        <!--Кнопка выхода -->
                        <Button Content="🚪 Выйти из аккаунта" 
                            Style="{StaticResource GrayButton}"
                            Width="250"
                            Click="BtnLogout_Click"
                            Margin="0,15,0,0"/> 
                    </StackPanel>
                </Border>

                <!--Заказы -->
                <Border Background="White" CornerRadius="20" Padding="40" Width="900" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="📦 Мои заказы" 
                                   FontSize="24" 
                                   FontWeight="Medium" 
                                   Foreground="Black" 
                                   TextAlignment="Center" 
                                   Margin="0,0,0,20"/>

                        <DataGrid x:Name="DataGridOrders"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="45"
                                  FontSize="14"
                                  Height="300">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8F9FA"/>
                                    <Setter Property="Foreground" Value="#2D3748"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}" Width="120"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:F2} ₽}" Width="100"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                                <DataGridTextColumn Header="Товаров" Binding="{Binding ItemsCount}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="TxtNoOrders" 
                                   Text="Заказов пока нет" 
                                   FontSize="18" 
                                   Foreground="Gray" 
                                   TextAlignment="Center" 
                                   Margin="0,20,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>