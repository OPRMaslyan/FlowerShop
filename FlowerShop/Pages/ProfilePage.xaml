<Page x:Class="FlowerShop.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Профиль" Height="800" Width="1000">
    <Grid Background="{StaticResource MainBackground}">

        <!--Верхняя панель -->
        <Border Height="80" Background="White" VerticalAlignment="Top">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,0">
                    <Image Source="/Images/logo.png" Height="40" Margin="0,0,10,0"/>
                    <TextBlock Text="Flower Shop" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Каталог" Style="{StaticResource MenuButton}" Click="BtnCatalog_Click" Margin="0,0,20,0"/>
                    <Button Content="О нас" Style="{StaticResource MenuButton}" Click="BtnAbout_Click" Margin="0,0,20,0"/>
                    <Button Content="Меню" Style="{StaticResource MenuButton}" Click="BtnMenu_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <Button Content="🛒" Style="{StaticResource IconButton}" Click="BtnCart_Click" Margin="0,0,10,0"/>
                    <Button Content="👤" Style="{StaticResource IconButton}" Click="BtnProfile_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!--Контент -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,80,0,0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">

                <!--Заголовок -->
                <TextBlock Text="👤 Мой профиль" 
                           FontSize="36" 
                           FontWeight="Bold" 
                           Foreground="Black" 
                           Margin="0,30,0,30" 
                           TextAlignment="Center"/>

                <!--Личные данные -->
                <Border Background="White" CornerRadius="20" Padding="40" Width="600" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="📋 Личные данные" FontSize="20" FontWeight="Bold" Foreground="Black" Margin="0,0,0,20"/>

                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Логин" FontSize="14" FontWeight="Medium" Foreground="#555" Margin="0,0,0,5"/>
                            <TextBox x:Name="TBoxUsername" Style="{StaticResource FilterTextBox}" IsEnabled="False"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Email" FontSize="14" FontWeight="Medium" Foreground="#555" Margin="0,0,0,5"/>
                            <TextBox x:Name="TBoxEmail" Style="{StaticResource FilterTextBox}" IsEnabled="False"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Роль" FontSize="14" FontWeight="Medium" Foreground="#555" Margin="0,0,0,5"/>
                            <TextBox x:Name="TBoxRole" Style="{StaticResource FilterTextBox}" IsEnabled="False"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,25">
                            <TextBlock Text="Дата регистрации" FontSize="14" FontWeight="Medium" Foreground="#555" Margin="0,0,0,5"/>
                            <TextBox x:Name="TBoxCreatedAt" Style="{StaticResource FilterTextBox}" IsEnabled="False"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="BtnEdit" Content="✏️ Изменить" Style="{StaticResource GreenButton}" Width="160" Margin="0,0,10,0" Click="BtnEdit_Click"/>
                            <Button x:Name="BtnSave" Content="💾 Сохранить" Style="{StaticResource GreenButton}" Width="160" Margin="0,0,10,0" Visibility="Collapsed" Click="BtnSave_Click"/>
                            <Button x:Name="BtnCancel" Content="❌ Отмена" Style="{StaticResource GrayButton}" Width="120" Visibility="Collapsed" Click="BtnCancel_Click"/>
                        </StackPanel>

                        <Button x:Name="BtnDeleteProfile" Content="🗑️ Удалить профиль" Style="{StaticResource GrayButton}" Width="220" Margin="0,25,0,0" Background="#DC3545" Click="BtnDeleteProfile_Click"/>
                        <TextBlock x:Name="TxtMessage" TextAlignment="Center" FontSize="14" Margin="0,15,0,0" Visibility="Collapsed"/>
                        <Button Content="🚪 Выйти" Style="{StaticResource GrayButton}" Width="200" Margin="0,15,0,0" Click="BtnLogout_Click"/>
                    </StackPanel>
                </Border>

                <!-- Заказы -->
                <Border Background="White" CornerRadius="20" Padding="30" Width="800" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="📦 Мои заказы" FontSize="20" FontWeight="Bold" Foreground="Black" TextAlignment="Center" Margin="0,0,0,20"/>

                        <!-- 👇 ItemsControl, НЕ DataGrid -->
                        <ItemsControl x:Name="ItemsControlOrders">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA" CornerRadius="12" Padding="20" Margin="0,0,0,12" BorderBrush="#E0E0E0" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="№" FontSize="12" Foreground="#777"/>
                                                <TextBlock Text="{Binding Id}" FontSize="16" FontWeight="Bold"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Дата" FontSize="12" Foreground="#777"/>
                                                <TextBlock Text="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}" FontSize="14"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="Сумма" FontSize="12" Foreground="#777"/>
                                                <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:F2} ₽}" FontSize="14" FontWeight="Bold" Foreground="DarkGreen"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                <TextBlock Text="Статус" FontSize="12" Foreground="#777"/>
                                                <Border Background="{Binding StatusColor}" CornerRadius="8" Padding="8,4" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Status}" FontSize="13" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                <TextBlock Text="Товаров" FontSize="12" Foreground="#777"/>
                                                <TextBlock Text="{Binding ItemsCount}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <Button Content="👁️ Детали" Style="{StaticResource GrayButton}" FontSize="12" Height="35" Width="100" Click="BtnOrderDetails_Click" Tag="{Binding Id}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="TxtNoOrders" Text="Заказов пока нет" FontSize="18" Foreground="Gray" TextAlignment="Center" Margin="0,30,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>