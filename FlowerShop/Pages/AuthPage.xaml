<Page x:Class="FlowerShop.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход" Height="800" Width="1000">
    <Grid>
        <!-- Градиентный фон -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#7FFF00" Offset="0"/>
                <GradientStop Color="#50FFC0" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Центральный контейнер -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="910" Height="724">

            <!-- Логотип -->
            <TextBlock FontSize="36" FontWeight="Bold" Foreground="Black" TextAlignment="Center" Margin="0,0,0,30">
                🌸 Flower Shop
            </TextBlock>

            <!-- Заголовок "Авторизация" -->
            <Border Background="White" CornerRadius="20" Padding="30,20" Width="600" Margin="0,0,0,30">
                <TextBlock FontSize="48" FontWeight="Bold" Foreground="Black" TextAlignment="Center">
                    Авторизация
                </TextBlock>
            </Border>

            <!-- Форма входа -->
            <Border Background="White" CornerRadius="20" Padding="40" Width="600">
                <StackPanel>
                    <TextBlock Text="Вход" FontSize="24" FontWeight="Medium" Foreground="Black" TextAlignment="Center" Margin="0,0,0,20"/>

                    <!-- Поле логина -->
                    <TextBox x:Name="TBoxLogin" 
                             Height="60" 
                             FontSize="18" 
                             Padding="15" 
                             BorderBrush="LightGray" 
                             BorderThickness="1" 
                             Margin="0,0,0,20"/>

                    <!-- Поле пароля -->
                    <PasswordBox x:Name="PBoxPassword" 
                                 Height="60" 
                                 FontSize="18" 
                                 Padding="15" 
                                 BorderBrush="LightGray" 
                                 BorderThickness="1" 
                                 Margin="0,0,0,20"/>

                    <!-- Кнопка "Войти" -->
                    <Button x:Name="BtnLogin" 
        Content="Войти" 
        Click="BtnLogin_Click"
        Height="50" 
        FontSize="20" 
        FontWeight="SemiBold"
        Background="#E0E0E0" 
        Foreground="Black" 
        Margin="0,0,0,20">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="15">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Кнопка "Новый Пользователь" -->
                    <Button x:Name="BtnRegister" 
        Content="Новый Пользователь" 
        Click="BtnRegister_Click"
        Height="50" 
        FontSize="20" 
        FontWeight="SemiBold"
        Foreground="White" 
        Margin="0,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="#999999" CornerRadius="15">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#888888"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Сообщение об ошибке -->
            <TextBlock x:Name="TxtError" 
                       Foreground="Red" 
                       TextAlignment="Center" 
                       FontSize="16" 
                       Margin="0,20,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Page>