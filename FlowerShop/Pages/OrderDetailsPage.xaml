<Page x:Class="FlowerShop.Pages.OrderDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Детали заказа" Height="800" Width="1000">
    <Grid Background="{StaticResource MainBackground}">

        <!-- Верхняя панель -->
        <Border Height="80" Background="White" VerticalAlignment="Top">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,0">
                    <Image Source="/Images/logo.png" Height="40" Margin="0,0,10,0"/>
                    <TextBlock Text="Flower Shop" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Каталог" Style="{StaticResource MenuButton}" Click="BtnCatalog_Click" Margin="0,0,20,0"/>
                    <Button Content="О нас" Style="{StaticResource MenuButton}" Click="BtnAbout_Click" Margin="0,0,20,0"/>
                    <Button Content="Меню" Style="{StaticResource MenuButton}" Click="BtnMenu_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <Button Content="🛒" Style="{StaticResource IconButton}" Click="BtnCart_Click" Margin="0,0,10,0"/>
                    <Button Content="👤" Style="{StaticResource IconButton}" Click="BtnProfile_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Контент -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,80,0,0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">

                <!-- Заголовок -->
                <TextBlock Text="Заказ" x:Name="TxtOrderTitle"
                           FontSize="36" FontWeight="Bold" Foreground="Black" 
                           Margin="0,30,0,30" TextAlignment="Center"/>

                <!-- Информация о заказе -->
                <Border Background="White" CornerRadius="20" Padding="30" Width="800" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Дата" FontSize="14" Foreground="#555"/>
                            <TextBlock x:Name="TxtOrderDate" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Статус" FontSize="14" Foreground="#555"/>
                            <Border x:Name="BadgeStatus" CornerRadius="8" Padding="10,5" HorizontalAlignment="Left">
                                <TextBlock x:Name="TxtStatus" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Список товаров -->
                <Border Background="White" CornerRadius="20" Padding="30" Width="800" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Товары" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                        <ItemsControl x:Name="ItemsControlItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA" CornerRadius="12" Padding="15" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" 
                                       Text="{Binding FlowerName}" 
                                       FontSize="16" 
                                       FontWeight="Medium" 
                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" 
                                       Text="{Binding Price, StringFormat={}{0:F2} ₽}" 
                                       FontSize="14" 
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" 
                                       Text="{Binding Quantity}" 
                                       FontSize="14" 
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" 
                                       Text="{Binding Subtotal, StringFormat={}{0:F2} ₽}" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Foreground="DarkGreen" 
                                       HorizontalAlignment="Right" 
                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Итого -->
                <Border Background="White" CornerRadius="20" Padding="30" Width="800" Margin="0,0,0,30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Итого:" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" x:Name="TxtTotal" Text="0.00 ₽" FontSize="32" FontWeight="Bold" Foreground="DarkGreen"/>
                    </Grid>
                </Border>

                <!-- Кнопка назад -->
                <Button Content="Назад к профилю" Style="{StaticResource GrayButton}" Width="250" Margin="0,0,0,20" Click="BtnBack_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>