<Page x:Class="FlowerShop.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация" Height="800" Width="1000">
    <Grid Background="{StaticResource MainBackground}">

        <!--Скролл для контента -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,40">

                <!--Логотип -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <Image Source="/Images/logo.png" Height="60" Margin="0,0,10,0"/>
                    <TextBlock Text="Flower Shop" FontSize="36" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                </StackPanel>

                <!--Заголовок -->
                <Border Background="White" CornerRadius="20" Padding="30,20" Width="600" Margin="0,0,0,30">
                    <TextBlock Text="Регистрация" FontSize="48" FontWeight="Bold" Foreground="Black" TextAlignment="Center"/>
                </Border>

                <!--Форма -->
                <Border Background="White" CornerRadius="20" Padding="40" Width="600" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Создание аккаунта" FontSize="24" FontWeight="Medium" Foreground="Black" TextAlignment="Center" Margin="0,0,0,20"/>

                        <!--Логин с подсказкой -->
                        <Grid Margin="0,0,0,20">
                            <TextBox x:Name="TBoxUsername" 
                                     Height="60" FontSize="18" Padding="15" 
                                     BorderBrush="LightGray" BorderThickness="1"
                                     TextChanged="TBoxInput_TextChanged"/>
                            <TextBlock Text="Логин" 
                                       FontSize="18" Foreground="Gray" 
                                       Margin="15,0,0,0" VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TBoxUsername}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!--Email с подсказкой -->
                        <Grid Margin="0,0,0,20">
                            <TextBox x:Name="TBoxEmail" 
                                     Height="60" FontSize="18" Padding="15" 
                                     BorderBrush="LightGray" BorderThickness="1"
                                     TextChanged="TBoxInput_TextChanged"/>
                            <TextBlock Text="Email" 
                                       FontSize="18" Foreground="Gray" 
                                       Margin="15,0,0,0" VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TBoxEmail}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!--Пароль с подсказкой -->
                        <Grid Margin="0,0,0,20">
                            <PasswordBox x:Name="PBoxPassword" 
                                         Height="60" FontSize="18" Padding="15" 
                                         BorderBrush="LightGray" BorderThickness="1"
                                         PasswordChanged="PBoxPassword_PasswordChanged"
                                         PreviewKeyDown="PBoxPassword_KeyDown"/>
                            <TextBlock x:Name="TxtPasswordHint" 
                                       Text="Пароль" 
                                       FontSize="18" Foreground="Gray" 
                                       Margin="15,0,0,0" VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                        </Grid>

                        <!--Подтверждение пароля -->
                        <Grid Margin="0,0,0,20">
                            <PasswordBox x:Name="PBoxPasswordConfirm" 
                                         Height="60" FontSize="18" Padding="15" 
                                         BorderBrush="LightGray" BorderThickness="1"
                                         PasswordChanged="PBoxPasswordConfirm_PasswordChanged"
                                         PreviewKeyDown="PBoxPassword_KeyDown"/>
                            <TextBlock x:Name="TxtPasswordConfirmHint" 
                                       Text="Повторите пароль" 
                                       FontSize="18" Foreground="Gray" 
                                       Margin="15,0,0,0" VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                        </Grid>

                        <!--Кнопки -->
                        <Button x:Name="BtnRegister" 
                                Content="Зарегистрироваться" 
                                Click="BtnRegister_Click"
                                Style="{StaticResource GreenButton}"
                                Width="500"
                                Margin="0,0,0,15"/>

                        <Button x:Name="BtnCancel" 
                                Content="Отмена" 
                                Click="BtnCancel_Click"
                                Style="{StaticResource GrayButton}"
                                Width="500"/>
                    </StackPanel>
                </Border>

                <!--Ошибка -->
                <TextBlock x:Name="TxtError" 
                           Foreground="Red" 
                           TextAlignment="Center" 
                           FontSize="16" 
                           Margin="0,10,0,40"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>