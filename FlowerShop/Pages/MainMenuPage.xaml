<Page x:Class="FlowerShop.Pages.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главное меню" Height="800" Width="1000">
    <Grid Background="White">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="TxtWelcome" FontSize="28" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,30"/>
            <Button Content="Каталог цветов" Click="BtnFlowers_Click" Width="200" Height="50" FontSize="18" Background="DarkGreen" Foreground="White" Margin="0,0,0,10"/>
            <Button Content="Выйти" Click="BtnLogout_Click" Width="200" Height="50" FontSize="18" Background="LightGray" Foreground="Black" Margin="0,20,0,0"/>
        </StackPanel>
    </Grid>
</Page>