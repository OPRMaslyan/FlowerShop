<Page x:Class="FlowerShop.Pages.FlowersCatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Каталог цветов" Height="800" Width="1000">
    <Grid>
        <!-- Градиентный фон -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#7FFF00" Offset="0"/>
                <GradientStop Color="#50FFC0" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Верхняя панель -->
        <Border Height="80" Background="White" VerticalAlignment="Top">
            <Grid>
                <!-- Левая часть: логотип -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,0">
                    <TextBlock Text="🌸 Flower Shop" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Центр: навигация -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Каталог" 
                        Click="BtnCatalog_Click"
                        FontSize="16" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Padding="10" 
                        Margin="0,0,20,0"/>
                    <Button Content="О нас" 
                        Click="BtnAbout_Click"
                        FontSize="16" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Padding="10"/>
                </StackPanel>

                <!-- Правая часть: корзина и профиль -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <Button Content="🛒" FontSize="24" Background="Transparent" BorderThickness="0" Width="50" Height="50" Click="BtnCart_Click"/>
                    <Button Content="👤" FontSize="24" Background="Transparent" BorderThickness="0" Width="50" Height="50" Click="BtnProfile_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,80,0,0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">
                <TextBlock Text="Каталог Цветы" FontSize="48" FontWeight="Bold" Foreground="Black" Margin="0,30,0,40"/>

                <!-- Сетка карточек -->
                <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,50">
                    <ItemsControl x:Name="ItemsControlFlowers">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="20" Padding="15" Margin="15" Width="300" Height="355">
                                    <StackPanel>
                                        <!-- Изображение с закруглёнными углами -->
                                        <Border CornerRadius="10" ClipToBounds="True" Width="270" Height="200">
                                            <Image Source="{Binding Imageurl}" Stretch="UniformToFill"/>
                                        </Border>
                                        <!-- Название и цена -->
                                        <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" Margin="0,10,0,5"/>
                                        <TextBlock>
                                            
            <Run Text="Цена за шт: "/>
            <Run Text="{Binding Price, StringFormat={}{0:F2} ₽}" FontWeight="Bold"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Category.Name}" Foreground="Gray" Margin="0,5,0,10"/>
                                        <Button Content="В корзину" 
                                            Click="BtnAddToCart_Click"
                                            Tag="{Binding}" 
                                            Width="270" 
                                            Height="35" 
                                            Background="DarkGreen" 
                                            Foreground="White" 
                                            FontWeight="Bold"/>         
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>