<Page x:Class="FlowerShop.Pages.AdminPanel.AdminFlowerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Добавление товара" Height="800" Width="1000">
    <Grid Background="{StaticResource MainBackground}">

        <!-- Верхняя панель -->
        <Border Height="80" Background="White" VerticalAlignment="Top">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,0">
                    <Image Source="pack://application:,,,/Images/logo.png" Height="40" Margin="0,0,10,0"/>
                    <TextBlock Text="Flower Shop" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Каталог" Style="{StaticResource MenuButton}" Click="BtnCatalog_Click" Margin="0,0,20,0"/>
                    <Button Content="О нас" Style="{StaticResource MenuButton}" Click="BtnAbout_Click" Margin="0,0,20,0"/>
                    <Button Content="Меню" Style="{StaticResource MenuButton}" Click="BtnMenu_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <Button Content="🛒" Style="{StaticResource IconButton}" Click="BtnCart_Click" Margin="0,0,10,0"/>
                    <Button Content="👤" Style="{StaticResource IconButton}" Click="BtnProfile_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Контент -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,80,0,0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">

                <!-- Заголовок -->
                <TextBlock Name="TxtTitle" Text="Добавление товара" FontSize="36" FontWeight="Bold" Foreground="Black" Margin="0,20,0,30" TextAlignment="Center"/>

                <!-- Форма -->
                <Border Background="White" CornerRadius="20" Padding="40" Width="700">
                    <StackPanel>

                        <!-- Название -->
                        <TextBlock Text="Название" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBox x:Name="TBoxName" Height="50" FontSize="16" Padding="15" BorderBrush="LightGray" BorderThickness="1" Margin="0,0,0,20"/>

                        <!-- Описание -->
                        <TextBlock Text="Описание" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBox x:Name="TBoxDescription" Height="100" FontSize="16" Padding="15" BorderBrush="LightGray" BorderThickness="1" Margin="0,0,0,20" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <!-- Цена -->
                        <TextBlock Text="Цена (₽)" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBox x:Name="TBoxPrice" Height="50" FontSize="16" Padding="15" BorderBrush="LightGray" BorderThickness="1" Margin="0,0,0,20" PreviewTextInput="TBoxPrice_PreviewTextInput"/>

                        <!-- Количество на складе -->
                        <TextBlock Text="Количество на складе" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBox x:Name="TBoxStock" Height="50" FontSize="16" Padding="15" BorderBrush="LightGray" BorderThickness="1" Margin="0,0,0,20" PreviewTextInput="TBoxPrice_PreviewTextInput"/>

                        <!-- Категория -->
                        <TextBlock Text="Категория" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="ComboBoxCategories" Height="50" FontSize="16" Padding="10" BorderBrush="LightGray" BorderThickness="1" Margin="0,0,0,20" SelectionChanged="ComboBoxCategories_SelectionChanged"/>

                        <!-- Загрузка фото -->
                        <TextBlock Text="Фото товара" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Border Background="#F5F5F5" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <Image x:Name="ImagePreview" Height="200" Margin="0,0,0,15" Stretch="Uniform"/>
                                <Button Content="Выбрать изображение" Style="{StaticResource GrayButton}" Width="250" Click="BtnSelectImage_Click"/>
                                <TextBlock x:Name="TxtImageName" Text="Файл не выбран" Foreground="Gray" TextAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Кнопки -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button Content="Сохранить" Style="{StaticResource GreenButton}" Width="200" Click="BtnSave_Click" Margin="0,0,20,0"/>
                            <Button Content="Отмена" Style="{StaticResource GrayButton}" Width="200" Click="BtnCancel_Click"/>
                        </StackPanel>

                        <!-- Сообщение об ошибке -->
                        <TextBlock x:Name="TxtError" Foreground="Red" TextAlignment="Center" FontSize="16" Margin="0,20,0,0" Visibility="Collapsed"/>

                        <!-- Сообщение об успехе -->
                        <TextBlock x:Name="TxtSuccess" Foreground="Green" TextAlignment="Center" FontSize="16" Margin="0,20,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>