<Page x:Class="FlowerShop.Pages.AdminPanel.AdminOrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление заказами" Height="800" Width="1000">
    <Grid Background="{StaticResource MainBackground}">

        <!--Верхняя панель -->
        <Border Height="80" Background="White" VerticalAlignment="Top">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,0">
                    <Image Source="/Images/logo.png" Height="40" Margin="0,0,10,0"/>
                    <TextBlock Text="Flower Shop Admin" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <Button Content="🏠 На главную" Style="{StaticResource MenuButton}" Click="BtnDashboard_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!--Контент -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,80,0,0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">

                <!--Заголовок -->
                <TextBlock Text="📦 Управление заказами" 
                           FontSize="36" 
                           FontWeight="Bold" 
                           Foreground="Black" 
                           Margin="0,30,0,30" 
                           TextAlignment="Center"/>

                <!--Список заказов -->
                <Border Background="White" CornerRadius="20" Padding="30" Width="900" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="Все заказы" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                        <ItemsControl x:Name="ItemsControlOrders">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA" 
                                            CornerRadius="15" 
                                            Padding="20" 
                                            Margin="0,0,0,15"
                                            BorderBrush="#E0E0E0"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!--Верхняя строка: Номер, Дата, Клиент, Сумма -->
                                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="200"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="150"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="№ Заказа" FontSize="12" Foreground="#757575"/>
                                                    <TextBlock Text="{Binding Id}" FontSize="18" FontWeight="Bold" Foreground="#212121"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Дата" FontSize="12" Foreground="#757575"/>
                                                    <TextBlock Text="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" 
                                                               FontSize="14" 
                                                               FontWeight="Medium"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Клиент" FontSize="12" Foreground="#757575"/>
                                                    <TextBlock Text="{Binding CustomerName}" 
                                                               FontSize="14" 
                                                               FontWeight="Medium"/>
                                                    <TextBlock Text="{Binding CustomerPhone}" 
                                                               FontSize="12" 
                                                               Foreground="Gray"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" HorizontalAlignment="Right">
                                                    <TextBlock Text="Сумма" FontSize="12" Foreground="#757575"/>
                                                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:F2} ₽}" 
                                                               FontSize="18" 
                                                               FontWeight="Bold" 
                                                               Foreground="DarkGreen"/>
                                                </StackPanel>
                                            </Grid>

                                            <!--Средняя строка: Статус + Товары -->
                                            <Grid Grid.Row="1" Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="250"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!--Выбор статуса -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Статус заказа" FontSize="12" Foreground="#757575" Margin="0,0,0,5"/>
                                                    <ComboBox x:Name="ComboBoxStatus"
                                                              Tag="{Binding Id}"
                                                              Width="240" 
                                                              Height="40"
                                                              FontSize="14" 
                                                              Padding="10,0"
                                                              SelectionChanged="ComboBoxStatus_SelectionChanged"
                                                              Loaded="ComboBoxStatus_Loaded">
                                                        <ComboBoxItem Content="Ожидает оплаты" Tag="Pending"/>
                                                        <ComboBoxItem Content="Оплачен" Tag="Paid"/>
                                                        <ComboBoxItem Content="Обрабатывается" Tag="Processing"/>
                                                        <ComboBoxItem Content="Отправлен" Tag="Shipped"/>
                                                        <ComboBoxItem Content="Доставлен" Tag="Delivered"/>
                                                        <ComboBoxItem Content="Отменён" Tag="Cancelled"/>
                                                    </ComboBox>
                                                </StackPanel>

                                                <!--Товары -->
                                                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                                    <TextBlock Text="Товары" FontSize="12" Foreground="#757575" Margin="0,0,0,5"/>
                                                    <TextBlock Text="{Binding ItemsList}" 
                                                               FontSize="14" 
                                                               TextWrapping="Wrap"
                                                               Foreground="#424242"/>
                                                </StackPanel>
                                            </Grid>

                                            <!--Нижняя строка: Кнопки -->
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="👁️ Детали" 
                                                        Style="{StaticResource GrayButton}"
                                                        Width="100" Height="35"
                                                        FontSize="12"
                                                        Margin="0,0,10,0"
                                                        Tag="{Binding Id}"
                                                        Click="BtnDetails_Click"/>
                                                <Button Content="🗑️ Удалить" 
                                                        Background="#DC3545"
                                                        Style="{StaticResource GrayButton}"
                                                        Width="100" Height="35"
                                                        FontSize="12"
                                                        Tag="{Binding Id}"
                                                        Click="BtnDelete_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="TxtNoOrders" 
                                   Text="Заказов нет" 
                                   FontSize="20" 
                                   Foreground="Gray" 
                                   TextAlignment="Center" 
                                   Margin="0,30,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>