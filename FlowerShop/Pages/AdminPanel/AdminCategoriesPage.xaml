<Page x:Class="FlowerShop.Pages.AdminPanel.AdminCategoriesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление категориями" Height="800" Width="1000">
    <Grid Background="{StaticResource MainBackground}">

        <!-- Верхняя панель -->
        <Border Height="80" Background="White" VerticalAlignment="Top">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,0">
                    <Image Source="/Images/logo.png" Height="40" Margin="0,0,10,0"/>
                    <TextBlock Text="Flower Shop" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Каталог" Style="{StaticResource MenuButton}" Click="BtnCatalog_Click" Margin="0,0,20,0"/>
                    <Button Content="О нас" Style="{StaticResource MenuButton}" Click="BtnAbout_Click" Margin="0,0,20,0"/>
                    <Button Content="Меню" Style="{StaticResource MenuButton}" Click="BtnMenu_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <Button Content="🛒" Style="{StaticResource IconButton}" Click="BtnCart_Click" Margin="0,0,10,0"/>
                    <Button Content="👤" Style="{StaticResource IconButton}" Click="BtnProfile_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Контент -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,80,0,0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">

                <!-- Заголовок + Кнопка добавить -->
                <Grid Width="900" Margin="0,30,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" 
                               Text="Категории" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               Foreground="Black" 
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" 
                            Content="Добавить категорию" 
                            Style="{StaticResource GreenButton}" 
                            Width="250" 
                            Click="BtnAddCategory_Click"/>
                </Grid>

                <!-- Таблица категорий -->
                <Border Background="White" 
                        CornerRadius="20" 
                        Padding="25" 
                        Width="900"
                        Margin="0,0,0,30">

                    <DataGrid x:Name="DataGridCategories"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowHeight="55"
                              FontSize="14"
                              BorderThickness="0"
                              Background="Transparent">

                        <!-- Стиль заголовков -->
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8F9FA"/>
                                <Setter Property="Foreground" Value="#2D3748"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="15"/>
                                <Setter Property="Padding" Value="15,12"/>
                                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <!-- Стиль ячеек -->
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="15,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}" 
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#C6F6D5"/>
                                        <Setter Property="Foreground" Value="#1A5F3C"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0FFF4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <!-- Колонки -->
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" 
                                               Binding="{Binding Id}" 
                                               Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#718096"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Название" 
                                               Binding="{Binding Name}" 
                                               Width="250">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Setter Property="FontSize" Value="15"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Описание" 
                                               Binding="{Binding Description}" 
                                               Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#4A5568"/>
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Товаров" 
                                               Binding="{Binding FlowersCount}" 
                                               Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#2D3748"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Колонка с кнопками действий -->
                            <DataGridTemplateColumn Header="Действия" 
                                                   Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" 
                                                    HorizontalAlignment="Center">
                                            <Button Content="🗑️" 
                                                    Style="{StaticResource IconButton}"
                                                    Width="45" 
                                                    Height="45" 
                                                    FontSize="18"
                                                    Tag="{Binding Id}"
                                                    Click="BtnDeleteCategory_Click"
                                                    ToolTip="Удалить категорию"/>
                                            <Button Content="✏️" 
                                                    Style="{StaticResource IconButton}"
                                                    Width="45" 
                                                    Height="45" 
                                                    FontSize="18"
                                                    Tag="{Binding Id}"
                                                    Click="BtnEditCategory_Click"
                                                    ToolTip="Редактировать категорию"/>               
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Пустой результат -->
                <TextBlock x:Name="TxtNoCategories" 
                           Text="Категории не найдены" 
                           FontSize="24" 
                           Foreground="#718096" 
                           TextAlignment="Center" 
                           Margin="0,50,0,0" 
                           Visibility="Collapsed"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>